
<% points_by_pilote.each do |pilote, data| %>
  <div class="cadre-record">
    <div class="row col-data col-centered m-0 p-0">
      <div class="col-1 col-position">
        <%= data[:index] %>
      </div>
      <div class="col-10 ps-4">
        <%= pilote.nom %>
      </div>
      <div class="col-1 col-score">
        <%= data[:score] %>
      </div>
    </div>
  </div>
<% end %>
