  <%# afficher les détails de l'event selectionné %>
  
  <table width="100%">
    <thead>
      <tr>
        <th class="enteteGp">Ligue</th>
        <th class="enteteGp">Saison</th>
        <th class="enteteGp">Division</th>
        <th class="enteteGp">N°</th>
        <th class="enteteGp">Date</th>
        <th class="enteteGp">Pays</th>
        <th class="enteteGp">Drapeau</th>
        <th class="enteteGp">Carte</th>
     
      </tr>
    </thead>

    <tbody>
      <tr>
        <td class="eventactif">
          <%= Ligue.find(@ligueId).nom %>
        </td>
        <td class="eventactif">
          <%= Saison.find(@saisonId).nom %>
        </td>
        <td class="eventactif">
          <%= Division.find(@divisionId).nom %>
        </td>
        <td class="eventactif">
            <%= Event.find(@eventId).numero %>
        </td>
          <td class="eventactif">
          <% if Event.find(@eventId).date.present? %>
            <% datetime = Event.find(@eventId).date.to_date %>
            <%= datetime.strftime("%d/%m/%y") %>
          <% end %>
        </td>
        <td class="eventactif">
              <% circuitId = Event.find(@eventId).circuit_id %> 
              <%= Circuit.find(circuitId).pays %>
        </td>
        <td>
          <%# if (Circuit.find(circuitId).drapeau).blank? %>
          <%# else %>
            <%#= image_tag(Circuit.find(circuitId).drapeau, style: "width: 50px; display: block", class: "img-fluid rounded") %> 
          <%# end %>
        </td>
        <td>
          <%# if (Circuit.find(circuitId).carte).blank? %>
          <%# else %>
              <%#= image_tag(Circuit.find(circuitId).carte, style: "width: 50px; display: block", class: "img-fluid rounded") %>  
          <%# end %>
        </td>

      </tr>
  </tbody>
</table>

<hr/>