<%= form_with(model: event) do |form| %>
  <% if event.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(event.errors.count, "error") %> prohibited this event from being saved:</h2>

      <ul>
        <% event.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :date, style: "display: block" %>
    <%= form.date_field :date %>
  </div>

  <div>
    <%= form.label :horaire, style: "display: block" %>
    <%= form.time_field :horaire %>
  </div>

  <div>
    <%= form.label :numero, style: "display: block" %>
    <%= form.number_field :numero %>
  </div>

  <div>
    <%= form.label :circuit_id, style: "display: block" %>
    <%= form.text_field :circuit_id %>
  </div>

  <div>
    <%= form.label :saison_id, style: "display: block" %>
    <%= form.text_field :saison_id %>
  </div>

  <div>
    <%= form.label :division_id, style: "display: block" %>
    <%= form.text_field :division_id %>
  </div>

  <div>
    <%= form.label :ligue_id, style: "display: block" %>
    <%= form.text_field :ligue_id %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
