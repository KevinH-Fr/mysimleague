<%= form_with(model: ligue) do |form| %>
  <% if ligue.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(ligue.errors.count, "error") %> prohibited this ligue from being saved:</h2>

      <ul>
        <% ligue.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>


  <div class="cadre-record">
    <div class="row">

      <div class="col-10 mx-auto ">
        <div class="input-group">
          <%= form.label :nom, class:"input-group-text label-with-format" %>
          <%= form.text_field :nom,  required: true, class:"form-control field-with-format" %>
        </div>
        <div class="input-group">
          <%= form.label :description, class:"input-group-text label-with-format" %>
          <%= form.text_field :description, class:"form-control field-with-format" %>
        </div>
    
        <div class="field">
          <%= form.label :icon %>
          <%= form.file_field :icon %>
        </div>
      </div>

      <div class="col-2 col-btn">
        <button type="submit" class="btn btn-valider">
          <span><i class="fa-solid fa-square-check"></i> </span>
        </button>
      </div>
    </div>
  </div>
<% end %>
