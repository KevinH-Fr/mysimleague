<%= turbo_stream.append :pilotes do %>
    <%= render @pilotes %>
<% end %>

<% if @pagy.next.present? %>
    <%= turbo_stream.replace :pagination do %>
        <%= turbo_frame_tag :pagination, loading: :lazy,
            src: pilotes_path(format: :turbo_stream,
            page: @pagy.next, q: params[:q]&.to_unsafe_h ) %>
    <% end %>
<% end %>
